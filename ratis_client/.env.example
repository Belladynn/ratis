# Ratis API endpoints — actual values live in .env.local (gitignored)
EXPO_PUBLIC_API_URL=<primary_api_base_url>
EXPO_PUBLIC_REWARDS_API_URL=<rewards_api_base_url>
EXPO_PUBLIC_PRODUCT_API_URL=<product_api_base_url>
# MapTiler API key for the Itinéraire map tiles (free tier, EU-hosted).
# Empty → the map renders a "Carte indisponible" fallback (no crash).
EXPO_PUBLIC_MAPTILER_KEY=<maptiler_api_key>
