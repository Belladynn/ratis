{
  "expo": {
    "name": "ratis_client",
    "slug": "ratis_client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "ratis",
      "app.ratis.client"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "app.ratis.client",
      "usesAppleSignIn": true,
      "supportsTablet": false
    },
    "android": {
      "package": "app.ratis.client",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Ratis a besoin de la caméra pour scanner tes tickets de caisse et les étiquettes électroniques."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Ratis utilise ta position pour détecter le magasin où tu scannes et t'afficher les prix autour de toi."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "ratis-client",
          "organization": "ratis"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.323873931243-5hfrqj4d29skfb9u69sr232j8chdl1b8"
        }
      ],
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "googleClientIdIos": "323873931243-5hfrqj4d29skfb9u69sr232j8chdl1b8.apps.googleusercontent.com",
      "googleClientIdAndroid": "323873931243-ocqbl7c606063emeegtqaec0g5fp6n6j.apps.googleusercontent.com",
      "googleClientIdWeb": "323873931243-ip8apitrai5fko1qeff0lkgkij4f1ge6.apps.googleusercontent.com",
      "sentryDsn": "https://5374c0382a462442f41528a71705167c@o4511250717540352.ingest.de.sentry.io/4511250729140304",
      "router": {},
      "eas": {
        "projectId": "ebcfd722-cece-4899-b194-22b05b6c0f83"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ebcfd722-cece-4899-b194-22b05b6c0f83"
    }
  }
}
