# Ratis env var examples — placeholder values, NEVER commit real secrets.
# pragma: allowlist secret  (whole file is placeholders)

# HSP3 — secret partagé n8n↔PA pour la reprise inversée du workflow
# db-write-pipeline. 32 bytes urandom base64. Distinct de ADMIN_API_KEY.
N8N_RESUME_SECRET=<random-32-bytes-base64>

# HSP4 — confinement de l'agent côté DB. Le rôle PG agent_read est créé
# par la migration 20260521_1100_apply_hsp4_agent_confinement. Le mot de
# passe vit en env (Hetzner secrets / Mac mini Keychain en prod, .env.local
# en dev). Le swap effectif (db_query → agent_read) est HSP5 — en HSP4 la
# capacité existe sans être consommée.
AGENT_READ_PASSWORD=<placeholder-agent-read-password-32-chars-min>
# Connection string pour le rôle agent_read (consommée par db_query en HSP5).
AGENT_DATABASE_URL=postgresql+psycopg://agent_read:<placeholder>@localhost:5432/ratis_dev
# Identité de l'agent qui propose des écritures DB (cf manifest.allowed_callers).
# Vocabulaire contrôlé : regex ^[a-z][a-z0-9_-]{2,31}$. Default compilé.
RATIS_AGENT_ID=claude-code-main

# ratis_batch_sirene_sync — SIRENE INSEE → stores (FR primary)
# Source : https://www.data.gouv.fr/fr/datasets/base-sirene-des-entreprises-et-de-leurs-etablissements-siren-siret/
SIRENE_BULK_URL=https://files.data.gouv.fr/insee-sirene/StockEtablissement_utf8.zip
# Géoplateforme IGN/BAN — batch geocoding endpoint (BAN historique décommissionné 2026-01)
GEOPLATEFORME_GEOCODE_URL=https://data.geopf.fr/geocodage
# Local directory for Parquet bulk cache (sirene ZIP is ~1 GB unzipped)
SIRENE_BULK_CACHE_DIR=/var/cache/ratis/sirene

# db-write-pipeline (audit L1) — feature-flag d'exécution prod. Doit valoir
# exactement 'true' (string match strict) pour autoriser le node Execute
# (HSP4 checksum) à committer en prod. Absent OU != 'true' = fail-safe DISABLED.
# Consommé par n8n via $env.DB_PIPELINE_EXECUTE_ENABLED dans le workflow ;
# se déclare dans infra/itops/docker-compose.yml service n8n.
DB_PIPELINE_EXECUTE_ENABLED=false

# ============================================================
# LOCAL DEV / SEED MODE  (templates dev + seed consolidés ici)
# ============================================================
# Copy to .env.local for dev mode  :  cp .env.example .env.local   (puis garder ENVIRONMENT=dev)
# Switch between modes via the Makefile :  make dev-up  |  make seed-up
# (chaque cible écrit le .env.local correspondant — voir docs/arch/ARCH_seed_test_data.md).
# `.env.local` is gitignored — never commit local secrets.
#
# `dev` mode targets the clean ratis_dev DB; `seed` mode targets ratis_seed
# (personas + scans, bootstrapped by `make seed-db-init` then `make seed-rebuild`).

# Active mode. `dev` (clean DB) ou `seed` (DB peuplée de personas).
ENVIRONMENT=dev

# Local PG running in docker compose (see docker-compose.yml service `postgres`).
# DEV  mode → DB ratis_dev :
DATABASE_URL=postgresql+psycopg://ratis:ratis@localhost:5432/ratis_dev  # pragma: allowlist secret
# SEED mode → même PG, DB distincte ratis_seed (décommenter en mode seed) :
# DATABASE_URL=postgresql+psycopg://ratis:ratis@localhost:5432/ratis_seed  # pragma: allowlist secret

# Redis cache + Celery broker (see docker-compose.yml service `redis`).
# Seed mode partage la même instance (DB index 0) — pas de jobs Celery à isoler.
REDIS_URL=redis://localhost:6379/0
