# tools/ — variables d'environnement (gitignored)
# Copier ce fichier en .env.local et remplir les valeurs réelles

# === Sentry → Notion webhook (tools/sentry_webhook.py) ===
# Secret HMAC configuré dans Sentry : Alerts → Webhook → Secret
SENTRY_WEBHOOK_SECRET=<your-sentry-webhook-secret>
# Token d'intégration Notion (secret_...)
NOTION_TOKEN=<your-notion-integration-token>
# ID de la base Notion 📋 Backlog
NOTION_DATABASE_ID=ba6d932f-5647-4035-9b73-b477f6d87181

# === Sentry CLI helper (scripts/sentry_recent.py) ===
# Token Sentry (User Auth Token) avec scopes `event:read` + `project:read`
# Crée un token : https://sentry.io/settings/account/api/auth-tokens/
SENTRY_API_TOKEN=<your-sentry-user-auth-token>
SENTRY_ORG=ratis
SENTRY_PROJECT=ratis-client
