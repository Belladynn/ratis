# ============================================================================
# Ratis — production environment template
# ============================================================================
# Copy to `.env.prod` (gitignored) and fill in real values, then run:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Every variable below is consumed by docker-compose.prod.yml. Variables marked
# [REQUIRED] use the compose `${VAR:?}` guard — the stack refuses to start if
# they are unset. The rest fall back to the default shown (the value already
# baked into the compose file); override only if your deployment differs.
#
# NEVER commit the filled-in .env.prod. NEVER put a real secret in THIS file.
# Placeholders below are deliberately fake ("CHANGE_ME...").
#
# Not env vars (handled out-of-band) — the RS256 JWT key PAIR is mounted as
# files, not passed as env:
#   ./secrets/jwt_private.pem -> /run/jwt/jwt_private.pem   (auth only — issuer)
#   ./secrets/jwt_public.pem  -> /run/jwt/jwt_public.pem    (auth/PA/LO/RW — verify)
# Generate them on the host (gen-jwt-keys.sh) — they never live in the repo.
# ============================================================================


# ----------------------------------------------------------------------------
# Shared infrastructure (Postgres / Redis)
# ----------------------------------------------------------------------------
# [REQUIRED] Postgres superuser password for the bundled postgres service.
# Also interpolated into every service's DATABASE_URL.
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password  # pragma: allowlist secret

# Redis connection URL. Default targets the bundled redis service (db 0).
# Per-service DB indexes (auth=0, PA=1, LO=2) are set in the compose file.
REDIS_URL=redis://redis:6379/0


# ----------------------------------------------------------------------------
# Cross-service / auth shared
# ----------------------------------------------------------------------------
# [REQUIRED] Shared symmetric key for internal service-to-service calls
# (auth/PA/LO/RW -> notifier, etc.). Same value across all 5 services.
INTERNAL_API_KEY=CHANGE_ME_internal_api_key  # pragma: allowlist secret

# JWT audience claim — must match across auth (issuer) and all verifiers.
JWT_AUDIENCE=ratis

# Internal base URLs (compose service-name DNS). Override only for a split
# deployment. The /api/v1 suffix is mandatory (clients append paths to it).
REWARDS_BASE_URL=http://rewards:8004/api/v1
NOTIFIER_URL=http://notifier:8005/api/v1/notify
AU_BASE_URL=http://auth:8001/api/v1
RW_BASE_URL=http://rewards:8004/api/v1


# ----------------------------------------------------------------------------
# ratis_auth (AU :8001)
# ----------------------------------------------------------------------------
# [REQUIRED] Google OAuth client ID (token audience for Sign-in with Google).
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
# Apple Sign-in client ID. Empty = Apple login disabled (Android-only build).
APPLE_CLIENT_ID=
# Stripe — subscription billing. Empty = payment routes return 503 in alpha.
STRIPE_SECRET_KEY=  # pragma: allowlist secret
STRIPE_WEBHOOK_SECRET=  # pragma: allowlist secret
# Access/refresh token lifetimes.
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
# [REQUIRED] Salt for RGPD account-deletion anonymisation (audit F-AU-3).
# Choose ONCE — rotating it orphans existing anonymised rows.
RGPD_ANONYMIZE_SALT=CHANGE_ME_rgpd_anonymize_salt  # pragma: allowlist secret


# ----------------------------------------------------------------------------
# Admin (shared by ratis_auth + ratis_rewards + ratis_product_analyser)
# ----------------------------------------------------------------------------
# [REQUIRED for rewards] Gate for the /admin/* router. >=32 chars enforced.
# Same key on AU/PA/RW (single admin device). On AU/PA the admin UI is simply
# not mounted when this is empty, so it is optional there but required on RW.
ADMIN_API_KEY=CHANGE_ME_admin_api_key_min_32_chars  # pragma: allowlist secret
# [REQUIRED for rewards] TOTP secret for admin mutations (base32).
ADMIN_TOTP_SECRET=CHANGE_ME_base32_totp_secret  # pragma: allowlist secret


# ----------------------------------------------------------------------------
# ratis_product_analyser (PA :8003) — incl. Celery worker
# ----------------------------------------------------------------------------
# [REQUIRED] Cloudflare R2 (S3-compatible) credentials for receipt images.
R2_ENDPOINT_URL=https://CHANGE_ME.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=CHANGE_ME_r2_access_key_id  # pragma: allowlist secret
R2_SECRET_ACCESS_KEY=CHANGE_ME_r2_secret_access_key  # pragma: allowlist secret
R2_BUCKET_NAME=ratis-receipts
# [REQUIRED] Shared HMAC secret n8n<->PA for the db-write-pipeline resume hook
# (HSP-3). Distinct from ADMIN_API_KEY; PA fails fast at boot if missing.
N8N_RESUME_SECRET=CHANGE_ME_n8n_resume_secret  # pragma: allowlist secret
# LLM receipt filter (Phase 2h). LLM_API_KEY empty = filter disabled, worker
# falls back to the legacy regex parser. Set provider/base/model to match.
LLM_PROVIDER=mistral
LLM_API_KEY=  # pragma: allowlist secret
LLM_BASE_URL=
LLM_MODEL=
# Alpha debug instrumentation. true + ADMIN_API_KEY set => debug rows persisted.
STORE_DEBUG=false


# ----------------------------------------------------------------------------
# ratis_list_optimiser (LO :8002) — incl. Celery worker
# ----------------------------------------------------------------------------
# OSRM routing backend. Default = bundled osrm service (profile osrm-local).
# Point elsewhere (public OSRM / external host) if not self-hosting routing.
OSRM_BASE_URL=http://osrm:5000


# ----------------------------------------------------------------------------
# ratis_rewards (RW :8004)
# ----------------------------------------------------------------------------
# [REQUIRED] Per-provider cashback webhook signing secrets (audit MED — one
# secret per affiliate provider; rotate via the *_PREV companion, not shown).
CASHBACK_WEBHOOK_SECRET_AFFILAE=CHANGE_ME_affilae_webhook_secret  # pragma: allowlist secret
CASHBACK_WEBHOOK_SECRET_AWIN=CHANGE_ME_awin_webhook_secret  # pragma: allowlist secret
CASHBACK_WEBHOOK_SECRET_CJ=CHANGE_ME_cj_webhook_secret  # pragma: allowlist secret
# Legacy single webhook secret (pre per-provider split). Empty unless still used.
CASHBACK_WEBHOOK_SECRET=  # pragma: allowlist secret
# Gift-card provider (Runa) API key. Empty = gift-card issuance disabled.
GIFT_CARD_PROVIDER_KEY=  # pragma: allowlist secret


# ----------------------------------------------------------------------------
# ratis_notifier (NT :8005)
# ----------------------------------------------------------------------------
# Expo push endpoint. Default is the public Expo push service.
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send


# ----------------------------------------------------------------------------
# Migrations runner (profile: migrate)
# ----------------------------------------------------------------------------
# [REQUIRED] Password for the agent_read DB role created by HSP4-class
# migrations (CREATE ROLE agent_read). Migration fails fast without it.
AGENT_READ_PASSWORD=CHANGE_ME_agent_read_password  # pragma: allowlist secret


# ----------------------------------------------------------------------------
# Batch runners (profiles: batch_*) — external data sources
# ----------------------------------------------------------------------------
# OpenFoodFacts sync (batch_off_sync / batch_obp_sync).
OFF_USER_AGENT=Ratis/0.1 (+https://ratis.app)
OFF_API_BASE_URL=https://world.openfoodfacts.org
# OSM Overpass endpoint (batch_osm_sync).
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
# INSEE SIRENE bulk + Géoplateforme geocoding (batch_sirene_sync).
SIRENE_BULK_URL=https://files.data.gouv.fr/insee-sirene/StockEtablissement_utf8.zip
GEOPLATEFORME_GEOCODE_URL=https://data.geopf.fr/geocodage
SIRENE_BULK_CACHE_DIR=/var/cache/ratis/sirene


# ----------------------------------------------------------------------------
# Observability (all services)
# ----------------------------------------------------------------------------
# Sentry/GlitchTip DSN. Empty = SDK no-op (Sentry init is a no-op if unset).
SENTRY_DSN=
