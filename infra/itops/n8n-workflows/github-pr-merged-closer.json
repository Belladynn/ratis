    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Parse the PR body for closing references to GlitchTip issues.\n// Format expected in PR body : `glitchtip-issue:<id>` where <id> is the\n// numeric issue id surfaced by GlitchTip (PATCH /api/0/issues/<id>/).\nconst body = $json.pull_request?.body || '';\nconst re = /glitchtip-issue:(\\d+)/gi;\nconst matches = [...body.matchAll(re)].map(m => m[1]);\n\nif (matches.length === 0) {\n  return [{\n    json: {\n      _no_match: true,\n      _pr_number: $json.pull_request.number,\n      _pr_url: $json.pull_request.html_url,\n      _pr_title: $json.pull_request.title,\n    }\n  }];\n}\n\nreturn matches.map(issueId => ({\n  json: {\n    _no_match: false,\n    _glitchtip_issue_id: issueId,\n    _pr_number: $json.pull_request.number,\n    _pr_url: $json.pull_request.html_url,\n    _pr_title: $json.pull_request.title,\n  }\n}));\n"
      },
