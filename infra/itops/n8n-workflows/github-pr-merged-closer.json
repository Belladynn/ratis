        "language": "javaScript",
        "jsCode": "// HMAC-SHA256 verification of GitHub webhook signature.\n// Uses Webhook node options.rawBody=true → raw bytes at item.binary.data.\nconst crypto = require(\"crypto\");\n\nconst secret = $env.N8N_GITHUB_WEBHOOK_SECRET;\nif (!secret) throw new Error(\"N8N_GITHUB_WEBHOOK_SECRET env not set\");\n\nconst item = $input.first();\nconst itemJson = item.json || {};\nconst headers = itemJson.headers || {};\n\nconst presentedHeader = headers[\"x-hub-signature-256\"] || headers[\"X-Hub-Signature-256\"];\nif (!presentedHeader) return { json: { _hmac_status: \"missing_signature\", _statusCode: 401 } };\nif (!presentedHeader.startsWith(\"sha256=\")) return { json: { _hmac_status: \"invalid_format\", _statusCode: 401 } };\n\nconst binaryData = item.binary && item.binary.data;\nif (!binaryData || !binaryData.data) {\n  return { json: { _hmac_status: \"raw_body_unavailable_binary\", _statusCode: 500 } };\n}\n\nconst rawBuf = Buffer.from(binaryData.data, \"base64\");\nconst presented = presentedHeader.slice(\"sha256=\".length);\nconst expected = crypto.createHmac(\"sha256\", secret).update(rawBuf).digest(\"hex\");\n\nconst presentedBuf = Buffer.from(presented, \"hex\");\nconst expectedBuf = Buffer.from(expected, \"hex\");\nif (presentedBuf.length !== expectedBuf.length || !crypto.timingSafeEqual(presentedBuf, expectedBuf)) {\n  return { json: { _hmac_status: \"invalid_signature\", _statusCode: 401 } };\n}\n\nconst bodyObj = itemJson.body || {};\nreturn { json: { ...bodyObj, _hmac_status: \"ok\" } };"
      },
