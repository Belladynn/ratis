        "language": "javaScript",
        "jsCode": "// Emit a single JSONL line of metrics for Promtail/Loki ingestion.\n// Latency = wall-clock between workflow start (n8n's $execution.startedAt) and now.\nconst closed_count = $input.all().filter(i => !i.json._no_match).length;\n\nlet latency_ms = null;\ntry {\n  const startedAt = (typeof $execution !== 'undefined' && $execution?.startedAt) ? $execution.startedAt : null;\n  if (startedAt) {\n    const startMs = new Date(startedAt).getTime();\n    if (!Number.isNaN(startMs)) {\n      latency_ms = Date.now() - startMs;\n    }\n  }\n} catch (_) {\n  // $execution unavailable in this n8n version — leave latency_ms null.\n}\n\nconsole.log(JSON.stringify({\n  level: 'info',\n  ts: new Date().toISOString(),\n  service: 'n8n',\n  workflow: 'github-pr-merged-closer',\n  event: 'pr_merged_processed',\n  pr_number: $json._pr_number,\n  closed_count: closed_count,\n  latency_ms: latency_ms,\n}));\n\nreturn $input.all();\n"
