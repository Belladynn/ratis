# =============================================================================
# infra/itops/.env.example — copy to .env and fill in placeholders.
# .env is gitignored (root .gitignore: **/.env).
# Never commit real secrets; this file ships placeholders only.
# =============================================================================

# -----------------------------------------------------------------------------
# Healthchecks
# -----------------------------------------------------------------------------
# Port mapped on the host. Default 8000. Change if Mac mini already binds 8000.
HEALTHCHECKS_PORT=8000

# Public root URL for the Healthchecks UI. Used to build ping URLs.
# - Localhost (laptop SSH-tunneled or on the host itself): http://localhost:8000
# - Over Tailscale (recommended once tailnet up): http://<mac-mini-tailnet-name>:8000
# - Public proxy (Phase B): https://hc.ratis.app
HEALTHCHECKS_SITE_ROOT=http://localhost:8000
HEALTHCHECKS_SITE_NAME=Ratis Healthchecks

# Initial superuser created on first boot (login at /accounts/login/).
HEALTHCHECKS_SUPERUSER_EMAIL=<set-superuser-email>
HEALTHCHECKS_SUPERUSER_PASSWORD=<set-superuser-password>  # pragma: allowlist secret

# Django SECRET_KEY — generate a long random string. Example:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
HEALTHCHECKS_SECRET_KEY=<generate-django-secret-key>  # pragma: allowlist secret

# Allowed Host header values. "*" is fine on a private host behind Tailscale.
# Lock down in Phase B once we expose publicly.
HEALTHCHECKS_ALLOWED_HOSTS=*

# Internal ping URL — what cron jobs hit. Same host as SITE_ROOT in Phase A.
HEALTHCHECKS_PING_URL=http://localhost:8000/ping

# Outbound email — From address shown in alert emails.
HEALTHCHECKS_DEFAULT_FROM_EMAIL=healthchecks@ratis.app

# SMTP relay — leave HOST blank in Phase A. Configure in Phase B once we
# choose a transactional provider (Resend / Postmark / Mailgun).
# IMPORTANT: PORT must be a valid integer (not empty) — Healthchecks
# `envint()` crashes on empty values. Default 587 (SMTP submission) is inert
# while HOST is empty.
HEALTHCHECKS_EMAIL_HOST=
HEALTHCHECKS_EMAIL_PORT=587
HEALTHCHECKS_EMAIL_HOST_USER=
HEALTHCHECKS_EMAIL_HOST_PASSWORD=  # pragma: allowlist secret
HEALTHCHECKS_EMAIL_USE_TLS=False

# -----------------------------------------------------------------------------
# Phase B.1 — Uptime Kuma (HTTP/TCP probes + dashboard + alerting)
# -----------------------------------------------------------------------------
# Port mapped on the host. Default 3001. Override if conflicting.
# UI : http://localhost:3001 (premier accès = wizard création admin).
UPTIME_KUMA_PORT=3001

# -----------------------------------------------------------------------------
# Phase B.2 — Logs aggregation (Loki + Promtail)
# -----------------------------------------------------------------------------
# Loki HTTP port — bound on 127.0.0.1 only (consommé par Promtail intra-réseau
# Docker et par n8n localement en Phase C). Override si conflit avec un autre
# service local.
LOKI_PORT=3100

# Loki retention (DA-41) — défaut 14 jours = 336h. Format Go duration.
# Edit en cas de besoin (ex: 720h = 30 jours), pense à matcher
# `limits_config.retention_period` dans loki/loki-config.yml si tu changes ici.
LOKI_RETENTION_PERIOD=336h

# agent-mcp audit log directory (DA-48) — Promtail bind-mounts this dir
# read-only into the container (`/host-mcp-audit`) and tails `audit.log`.
# Default = Mac mini layout (XDG state dir for the `guillaume` account).
# Override on other hosts :
#   Linux dev box  : MCP_AUDIT_LOG_DIR=$HOME/.local/state/ratis-agent-mcp
#   macOS alt user : MCP_AUDIT_LOG_DIR=/Users/<user>/.local/state/ratis-agent-mcp
# If the directory or audit.log file does not exist yet (MCP never invoked),
# Promtail tails gracefully once it appears — no crash, no manual init.
MCP_AUDIT_LOG_DIR=/Users/guillaume/.local/state/ratis-agent-mcp

# -----------------------------------------------------------------------------
# Watchtower
# -----------------------------------------------------------------------------
# 6-field cron (seconds-precision). Default: 04:00 every day, Europe/Paris TZ.
# Reference: https://containrrr.dev/watchtower/arguments/#scheduling
WATCHTOWER_SCHEDULE=0 0 4 * * *

# Timezone for the cron above and Watchtower logs.
TZ=Europe/Paris

# -----------------------------------------------------------------------------
# n8n (Phase C — incident orchestration pipelines)
# -----------------------------------------------------------------------------
# Public Tailscale Funnel hostname — find via `tailscale status` on the host.
# Format : <machine-name>.<tailnet>.ts.net (no scheme, no trailing slash).
N8N_HOST=mac-mini.your-tailnet.ts.net

# CRITICAL secret — encrypts the credentials store (GitHub tokens, GlitchTip secrets via env).
# Generate with : openssl rand -hex 32
# Once set, NEVER change it without re-entering all credentials in the UI.
# Back up to Keychain : agent-mcp keychain set n8n-encryption-key
N8N_ENCRYPTION_KEY=<REQUIRED — openssl rand -hex 32>  # pragma: allowlist secret

# Basic auth on the n8n UI (Tailscale Funnel ACLs handle the network side ;
# this is defense in depth for the editor pages). Webhook URLs are NOT
# protected by basic auth — that's by design (Sentry/GitHub need to POST anonymously).
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=<REQUIRED — openssl rand -hex 16>  # pragma: allowlist secret

# Webhook secrets consumed by HMAC verification Code nodes inside workflows.
# Generate independently for each side : openssl rand -hex 32
# Mirror the same value on GitHub webhook config + batch composite action
# org secret (RATIS_BATCH_SENTINEL_WEBHOOK_SECRET côté GH).
N8N_GITHUB_WEBHOOK_SECRET=<REQUIRED — openssl rand -hex 32>  # pragma: allowlist secret
N8N_BATCH_SENTINEL_WEBHOOK_SECRET=<REQUIRED — openssl rand -hex 32>  # pragma: allowlist secret

# GlitchTip self-hosted (sunset Notion, cf ARCH_glitchtip_*.md).
# - GLITCHTIP_API_TOKEN : token admin pour PATCH /api/0/issues/<id>/ (consommé
#   par github-pr-merged-closer pour résoudre les issues GlitchTip à la fusion
#   d'une PR référençant `glitchtip-issue:<id>`).
#   Récupération : `security find-generic-password -s ratis-agent-mcp -a admin-glitchtip -w`
# - GLITCHTIP_DSN_N8N_WORKFLOWS : DSN du projet GlitchTip `n8n-workflows`
#   (consommé par batch-sentinel pour POST un event Sentry-formatted sur
#   l'endpoint d'ingest `/api/<project_id>/store/?sentry_key=<key>`).
#   Format : http://<public_key>@<host>:<port>/<project_id>
#   Récupération : `security find-generic-password -s ratis-agent-mcp -a ops-glitchtip-dsn-n8n-workflows -w`
GLITCHTIP_API_TOKEN=<REQUIRED — Keychain ratis-agent-mcp/admin-glitchtip>  # pragma: allowlist secret
GLITCHTIP_DSN_N8N_WORKFLOWS=<REQUIRED — Keychain ratis-agent-mcp/ops-glitchtip-dsn-n8n-workflows>  # pragma: allowlist secret

# Quarantine directory — fallback filesystem quand GlitchTip ingest échoue
# (3 retries down). Permet à un opérateur de rejouer manuellement le payload.
# REQUIRED — no default to fail-fast on misconfig. Mac mini default :
#   RATIS_QUARANTINE_DIR=/Users/guillaume/.local/share/ratis/tickets-quarantine
# Pre-create the directory with `mkdir -p $RATIS_QUARANTINE_DIR && chmod 700`
# before `docker compose up` so n8n container (UID 1000 `node`) can write to it.
RATIS_QUARANTINE_DIR=<REQUIRED — see comment above>

# Whitelist Node.js built-in modules accessible from n8n Code nodes via `require()`.
# n8n 1.x sandboxes Code nodes by default — `require('crypto')` is blocked without
# this env. We need crypto for HMAC-SHA256 verification of Sentry + GitHub webhooks
# (cf KP-NN n8n-quirks). Comma-separated list ; '*' for all (less safe).
NODE_FUNCTION_ALLOW_BUILTIN=crypto

# -----------------------------------------------------------------------------
# daily-digest workflow (V0.5) — moniteur de santé de la pipeline n8n
# -----------------------------------------------------------------------------
# Clé API REST de n8n. Créée dans l'UI : Settings → n8n API → Create an API key.
# Consommée par le workflow daily-digest pour lire GET /api/v1/executions et
# GET /api/v1/workflows (header X-N8N-API-KEY).
N8N_API_KEY=<REQUIRED — créer dans l'UI n8n : Settings → n8n API>  # pragma: allowlist secret

# Webhook entrant Discord, cible du POST quotidien du digest.
# Créé côté Discord : salon → Paramètres → Intégrations → Webhooks → Nouveau webhook.
# Format : https://discord.com/api/webhooks/<id>/<token>
N8N_DISCORD_DIGEST_WEBHOOK_URL=<REQUIRED — créer un webhook entrant sur le salon Discord cible>  # pragma: allowlist secret

# -----------------------------------------------------------------------------
# db-write-pipeline (SP4) — pipeline d'approbation des écritures DB
# -----------------------------------------------------------------------------
# Webhook entrant du workflow n8n db-write-pipeline. db_propose_write (agent-mcp)
# y POST les propositions, signées HMAC-SHA256 (header X-Ratis-Signature).
N8N_DB_PIPELINE_WEBHOOK_URL=<REQUIRED — URL du webhook n8n db-write-pipeline>  # pragma: allowlist secret
N8N_DB_PIPELINE_WEBHOOK_SECRET=<REQUIRED — openssl rand -hex 32>  # pragma: allowlist secret

# -----------------------------------------------------------------------------
# db-write-pipeline — revue LLM (SP5)
# -----------------------------------------------------------------------------
# Clé API Anthropic. Le workflow db-write-pipeline appelle l'API Messages
# (2 passes de revue : intention + cas-magique) via le nœud HTTP Request,
# header x-api-key. Le LLM-reviewer est un contexte neuf — aucun lien avec
# la session de l'agent qui a écrit la proposition.
ANTHROPIC_API_KEY=<REQUIRED — clé API Anthropic (console.anthropic.com)>  # pragma: allowlist secret

# -----------------------------------------------------------------------------
# db-write-pipeline — gate d'approbation humaine (SP6)
# -----------------------------------------------------------------------------
# SP6 — db-write-pipeline : gate d'approbation humaine.
# Base URL du service PA que n8n appelle pour enregistrer une proposition
# et la marquer expirée (timeout). Réseau Docker interne en prod.
PA_ADMIN_BASE_URL=http://ratis-product-analyser:8003
# Clé admin partagée — Bearer pour POST /api/v1/admin/db-approvals.
# DOIT être identique à l'ADMIN_API_KEY du service ratis_product_analyser.
ADMIN_API_KEY=<REQUIRED — identique à l'ADMIN_API_KEY du service PA>  # pragma: allowlist secret
