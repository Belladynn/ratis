# infra/hermes — env var KEYS only (no values, R17).
#
# Real secrets live in macOS Keychain (service `ratis-agent-mcp`) and are read
# at deploy time by deploy.sh. NEVER commit real values here.
#
# Fetch a value:  security find-generic-password -s ratis-agent-mcp -a <account> -w
#
# Two .env files get generated on the Mac mini:
#   ~/.hermes/.env       (Hermes agent + cron scripts + webhook)
#   ~/glitchtip/.env     (GlitchTip self-hosted stack)
# deploy.sh does NOT write these directly — list kept here for traceability.

# ───────────────────────── ~/.hermes/.env ─────────────────────────
# Telegram bridge
TELEGRAM_BOT_TOKEN=                  # Keychain account: ops-telegram-bot-token
TELEGRAM_HOME_CHANNEL=               # chat/channel id (not a secret, but env-driven)
TELEGRAM_HOME_CHANNEL_THREAD_ID=     # optional topic thread id

# Webhook receiver (GlitchTip → proxy → Hermes HMAC)
WEBHOOK_ENABLED=                     # "true"
WEBHOOK_PORT=                        # 8644
WEBHOOK_SECRET=                      # Keychain account: ops-hermes-webhook-secret
HERMES_WEBHOOK_SECRET=               # same value as WEBHOOK_SECRET (proxy.py reads this name)

# Daily digest / github-watch cron scripts
DIGEST_GITHUB_TOKEN=                 # Keychain account: ops-hermes-digest-github-token
DIGEST_GLITCHTIP_TOKEN=              # Keychain account: ops-hermes-digest-glitchtip-token
DIGEST_GLT_API=                      # http://localhost:8000/api/0 (not secret)
DIGEST_GLT_ORG=                      # ratis (not secret)
DIGEST_REPO=                         # Belladynn/ratis (not secret)

# Provider / model wiring (not secret)
OPENAI_BASE_URL=                     # https://chatgpt.com/backend-api/codex (openai-codex)

# Postmortem skill wiring (paths/timeouts, not secret)
HERMES_CLAUDE_PROJECTS_DIR=          # /opt/claude/projects
HERMES_POSTMORTEM_OUTPUT_DIR=        # /opt/claude/postmortems
HERMES_POSTMORTEM_TIMEOUT=

# Terminal / browser / debug toggles (not secret)
TERMINAL_LIFETIME_SECONDS=
TERMINAL_MODAL_IMAGE=
TERMINAL_TIMEOUT=
BROWSER_INACTIVITY_TIMEOUT=
BROWSER_SESSION_TIMEOUT=
BROWSERBASE_ADVANCED_STEALTH=
BROWSERBASE_PROXIES=
IMAGE_TOOLS_DEBUG=
MOA_TOOLS_DEBUG=
VISION_TOOLS_DEBUG=
WEB_TOOLS_DEBUG=

# ───────────────────────── ~/glitchtip/.env ─────────────────────────
SECRET_KEY=                          # Keychain account: ops-glitchtip-secret-key (Django SECRET_KEY)
POSTGRES_USER=                       # glitchtip (not secret)
POSTGRES_DB=                         # glitchtip (not secret)
POSTGRES_PASSWORD=                   # Keychain account: ops-glitchtip-postgres-password
DATABASE_URL=                        # postgres://glitchtip:<pw>@glitchtip-postgres:5432/glitchtip
REDIS_URL=                           # redis://glitchtip-valkey:6379/0 (not secret)
VALKEY_URL=                          # redis://glitchtip-valkey:6379/0 (not secret)
CELERY_BROKER_URL=                   # redis://glitchtip-valkey:6379/0 (not secret)
CELERY_RESULT_BACKEND=               # redis://glitchtip-valkey:6379/0 (not secret)
GLITCHTIP_DOMAIN=                    # http://localhost:8000 (not secret)
GLITCHTIP_MAX_EVENT_LIFE_DAYS=       # 90 (not secret)
ENABLE_USER_REGISTRATION=            # false (not secret)
DEFAULT_FROM_EMAIL=                  # not secret
EMAIL_URL=                           # may embed SMTP creds → Keychain ops-glitchtip-email-url if used
CSRF_TRUSTED_ORIGINS=                # http://localhost:8000 (not secret)
