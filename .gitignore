# ============================================================
gitignored/

# ============================================================
# OSM PBF DATA DUMPS — too large for git (multi-GB)
# ============================================================
batch/ratis_batch_osm_sync/data/*.pbf
batch/ratis_batch_osm_sync/data/*.osm.pbf
batch/ratis_batch_osm_sync/data/state.txt
batch/ratis_batch_osm_sync/data/.osmosis-wd/
CLAUDE.old.md

# ============================================================
# scan_debug_viewer outputs — local HTML reports per scan
# ============================================================
.scan-debug-*.html

# ============================================================
# Transient debug artifacts (worker logs, image extracts, caddy logs)
# Generated by scan-debug.sh + ad-hoc Python helpers — never commit.
# ============================================================
.tmp-*

# drive-capture — données captées + config locale (jamais dans le repo)
tools/drive-capture/captures/
tools/drive-capture/domains.txt
# drive-capture parser — base SQLite + NDJSON normalisé (données, pas le repo)
tools/drive-capture/**/drive_prices.db
tools/drive-capture/**/*.normalized.ndjson

# docs-mcp vector index (phase D agentic-docs) — regenerated on demand by
# scripts/build-docs-vector.py or the docs_reindex MCP tool. Local artefact.
.docs-vector-index.db
.docs-vector-index.db-journal
.docs-vector-index.db-wal
.docs-vector-index.db-shm
.mypy_cache/
.ruff_cache/
.pytest_cache/
