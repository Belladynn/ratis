DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
TEST_DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<test_dbname>
# RS256 JWT keys — generate with scripts/gen-jwt-keys.sh. ratis_auth is
# the sole issuer: it needs BOTH the private (sign) and public (verify)
# PEM. Per-environment pairs — never commit, never share across envs.
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_AUDIENCE=ratis
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
GOOGLE_CLIENT_ID=<google-oauth-client-id>
APPLE_CLIENT_ID=<apple-bundle-id>
INTERNAL_API_KEY=<random-hex-secret-shared-across-services>
# In production use the service hostname/load-balancer — never localhost.
# NOTIFIER_URL = full /notify endpoint URL (notifier_client POSTs directly).
NOTIFIER_URL=http://<notifier-host>:8005/api/v1/notify
STRIPE_SECRET_KEY=sk_test_<your-stripe-secret-key>  # pragma: allowlist secret
STRIPE_WEBHOOK_SECRET=whsec_<your-stripe-webhook-secret>  # pragma: allowlist secret
# REWARDS_BASE_URL must include /api/v1 — rewards_client builds
# f"{base}/rewards/referral/trigger" etc.
REWARDS_BASE_URL=http://<rewards-host>:8004/api/v1
# Admin endpoints (PR11 — subscription manage). Both must be set together ;
# if ADMIN_API_KEY is unset the /admin/* router is not mounted (404).
ADMIN_API_KEY=<random-hex-secret>
ADMIN_TOTP_SECRET=<base32-totp-secret>  # pragma: allowlist secret
REDIS_URL=redis://localhost:6379/0
# SENTRY_DSN — pointer vers GlitchTip self-hosted (sunset Notion+Sentry-SaaS, DA-47).
# Récupérer depuis Keychain au runtime :
#   export SENTRY_DSN=$(security find-generic-password -s ratis-agent-mcp -a ops-glitchtip-dsn-ratis-backend -w)
# Compatible Sentry SDK natif (aucune modif code). Absent = disabled (mode dev/test).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# RGPD anonymize salt (audit F-AU-3) — secret used to derive per-user anon
# UUIDs in delete_account. Must be a long random secret (>=32 chars).
# CRITICAL : NEVER rotate after first prod deletion ; rotating orphans
# every anonymized user's analytics rows (the salt is one-way — the only
# thing tying an anon UUID to its real user is the salt itself).
RGPD_ANONYMIZE_SALT=<random-hex-secret-32-bytes>  # pragma: allowlist secret
