DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<db>
# RS256 JWT public key — verify-only. This service cannot mint tokens.
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_AUDIENCE=ratis
INTERNAL_API_KEY=<internal_api_key>
ADMIN_API_KEY=<admin_api_key>
ADMIN_TOTP_SECRET=<base32_totp_secret>  # pragma: allowlist secret — generate via `python -m tools.setup_totp`
# Per-provider webhook signing secrets — one per cashback affiliate network
# (see ratis_settings.json § cashback.webhook_providers). A leak of one
# secret is contained to that single provider, not every network.
CASHBACK_WEBHOOK_SECRET_AFFILAE=<cashback_webhook_secret_affilae>  # pragma: allowlist secret
CASHBACK_WEBHOOK_SECRET_AWIN=<cashback_webhook_secret_awin>  # pragma: allowlist secret
CASHBACK_WEBHOOK_SECRET_CJ=<cashback_webhook_secret_cj>  # pragma: allowlist secret
# Optional — per-provider PREV secret, set during a 24h overlap rotation
# for that provider, then unset once the partner uses the new one.
CASHBACK_WEBHOOK_SECRET_AFFILAE_PREV=  # pragma: allowlist secret
CASHBACK_WEBHOOK_SECRET_AWIN_PREV=  # pragma: allowlist secret
CASHBACK_WEBHOOK_SECRET_CJ_PREV=  # pragma: allowlist secret
# PAYMENT_PROVIDER_KEY=sk_live_<stripe-secret-key>
REDIS_URL=redis://localhost:6379/0
# SENTRY_DSN — pointer vers GlitchTip self-hosted (sunset Notion+Sentry-SaaS, DA-47).
# Récupérer depuis Keychain au runtime :
#   export SENTRY_DSN=$(security find-generic-password -s ratis-agent-mcp -a ops-glitchtip-dsn-ratis-backend -w)
# Compatible Sentry SDK natif (aucune modif code). Absent = disabled (mode dev/test).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
