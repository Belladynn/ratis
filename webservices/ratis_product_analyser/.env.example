DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
TEST_DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<test_dbname>
# RS256 JWT public key — verify-only. This service cannot mint tokens.
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_AUDIENCE=ratis
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=ratis-ocr-images
REDIS_URL=redis://localhost:6379/0
INTERNAL_API_KEY=<random-hex-secret-shared-across-services>
# In production use the service hostname/load-balancer — never localhost.
# NOTIFIER_URL = full /notify endpoint URL (notifier_client POSTs directly).
NOTIFIER_URL=http://<notifier-host>:8005/api/v1/notify
# REWARDS_BASE_URL : worker (receipt_task) calls rewards_client for
# trigger_cashback_scan / notify_scan_accepted. /api/v1 prefix MANDATORY —
# rewards_client builds f"{base}/rewards/...".
REWARDS_BASE_URL=http://<rewards-host>:8004/api/v1
# Cross-service URL used by the admin mini UI to query AU's user lookup
# endpoints (/admin/users, /admin/users/{id}). Internal only — never
# reachable from the public internet. /api/v1 prefix MANDATORY (au_client
# builds f"{base}/admin/users...").
AU_BASE_URL=http://auth:8001/api/v1
# Cross-service URL used by the admin mini UI for the admin-settings
# pages (Bloc C). Calls /admin/settings/{section} (PUT), audit log
# (GET), confirm-2fa / cancel-pending POSTs on RW. Same internal-only
# constraint as AU_BASE_URL ; /api/v1 prefix MANDATORY.
RW_BASE_URL=http://rewards:8004/api/v1
# SENTRY_DSN — pointer vers GlitchTip self-hosted (sunset Notion+Sentry-SaaS, DA-47).
# Récupérer depuis Keychain au runtime :
#   export SENTRY_DSN=$(security find-generic-password -s ratis-agent-mcp -a ops-glitchtip-dsn-ratis-backend -w)
# Compatible Sentry SDK natif (aucune modif code). Absent = disabled (mode dev/test).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Langfuse — LLM tracing of the OCR pipeline's Anthropic call
# (worker_process_init → init_langfuse, cf ARCH_llm_observability.md).
# SELF-HOSTED ONLY : receipt text is purchase data → RGPD forbids Langfuse
# Cloud. The 3 vars are required together ; if PUBLIC/SECRET are set but
# LANGFUSE_HOST is missing, init_langfuse refuses to default to cloud and
# disables tracing (DA-LO4). All absent = tracing off (dev/test, like SENTRY_DSN).
# Worker runs in a container → LANGFUSE_HOST=http://host.docker.internal:3000.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# LLM filter (Phase 2h v2). The legacy LLM_FILTER_ENABLED gate has been
# retired ; provisioning ``LLM_API_KEY`` is the sole switch. Empty key =
# the v2 path stays inert and process_receipt falls back to the legacy
# parse_receipt regex parser. See PRIVACY.md § "LLM-assisted parsing" for
# the data flow disclosure.

# LLM provider switch — "mistral" (default), "anthropic", "ollama"
LLM_PROVIDER=mistral

# LLM credentials — single env var shared across all providers (mistral /
# anthropic / ollama). Swap-friendly : changing provider only needs 2 vars
# (LLM_PROVIDER + LLM_API_KEY) — no per-provider key juggling.
# Mistral : sk-... ; Anthropic : sk-ant-... ; Ollama : any non-empty placeholder.
LLM_API_KEY=

# LLM_BASE_URL : used by mistral + ollama (OpenAI-compatible path).
# Ignored when LLM_PROVIDER=anthropic (SDK targets Anthropic's endpoint
# directly).
LLM_BASE_URL=https://api.mistral.ai/v1

# LLM_MODEL : default selected per-provider when empty
# (mistral-small-latest / claude-haiku-4-5 / depends on Ollama install).
LLM_MODEL=

# Alpha debug instrumentation (PR #126). When true, process_receipt persists
# the OCR rich blocks + processed image + legacy parser output into
# scan_debug for replay via GET /api/v1/admin/scans/<scan_id>/debug.
# Default false — keeps R2 + DB cost zero outside of debug windows.
STORE_DEBUG=false
# Admin API key. When set, the admin router (/api/v1/admin/*) is mounted ;
# when absent, admin endpoints respond 404 (not 403). Auth via
# Authorization: Bearer <ADMIN_API_KEY>.
ADMIN_API_KEY=
