DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
TEST_DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<test_dbname>
INTERNAL_API_KEY=<random-hex-secret-shared-across-services>
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
# Redis URL — used for visible-push rate limiting (V1.1 achievements).
# SETNX cooldown keys live under `notif:push:rate:<user_id>:<notif_type>`.
REDIS_URL=redis://localhost:6379/0
# In production use the service hostname/load-balancer — never localhost.
# NOTIFIER_URL = full /notify endpoint URL (notifier_client POSTs directly).
NOTIFIER_URL=http://<notifier-host>:8005/api/v1/notify
# SENTRY_DSN — pointer vers GlitchTip self-hosted (sunset Notion+Sentry-SaaS, DA-47).
# Récupérer depuis Keychain au runtime :
#   export SENTRY_DSN=$(security find-generic-password -s ratis-agent-mcp -a ops-glitchtip-dsn-ratis-backend -w)
# Compatible Sentry SDK natif (aucune modif code). Absent = disabled (mode dev/test).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
